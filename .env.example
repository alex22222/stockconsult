# ============================================
# StockConsult 环境变量配置
# 复制为 .env 后填写真实值
# ============================================

# 开发模式: mock | investoday-rest | cloudbase
VITE_DATA_PROVIDER=mock

# investoday API Key (仅开发测试用，生产环境请使用云函数代理)
VITE_INVESTODAY_API_KEY=

# CloudBase 云函数代理地址 (生产环境使用)
# 格式: https://<环境ID>.service.tcloudbase.com/investoday-proxy
VITE_CLOUDBASE_API_URL=

# ============================================
# StockConsult 环境变量配置
# 复制为 .env 后填写真实值
# 注意: .env 文件已被 .gitignore 排除，不会提交到 Git
# ============================================

# 开发模式: mock | investoday-rest | cloudbase
VITE_DATA_PROVIDER=mock

# investoday API Key (仅开发测试用，生产环境请使用云函数代理)
# 获取地址: https://data-api.investoday.net/
VITE_INVESTODAY_API_KEY=

# CloudBase 云函数代理地址 (生产环境使用)
# 格式: https://<环境ID>.service.tcloudbase.com/investoday-proxy
VITE_CLOUDBASE_API_URL=

# ============================================
# 云函数 / 后端脚本环境变量
# ============================================

# Investoday 后端 API Key（可选；已添加腾讯/新浪/Eastmoney 免费数据源作为主力）
# 如 Investoday 资源包耗尽，系统会自动降级到免费数据源
INVESTODAY_API_KEY=

# 腾讯云 COS / CloudBase 凭据（investoday-proxy 云函数使用）
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=

# 飞书开放平台配置（daily_sentiment_report.py --send 使用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
